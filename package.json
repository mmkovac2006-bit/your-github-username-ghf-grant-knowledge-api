{
  "name": "ghf-grant-knowledge-api",
  "version": "1.0.0",
  "description": "Secure read-only middleware API for retrieving reusable Grant Halliburton Foundation grant language from Dropbox.",
  "main": "dist/server.js",
  "type": "commonjs",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "db:setup": "tsx scripts/setupDatabase.ts",
    "db:import-index": "tsx scripts/importIndexToDatabase.ts",
    "index:dropbox": "tsx scripts/indexDropboxArchive.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "express",
    "dropbox",
    "gpt-actions",
    "grant-writing"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.9",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
