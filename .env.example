NODE_ENV=development
PORT=3000

GHF_ACTION_API_KEY=replace_with_long_random_secret

DROPBOX_CLIENT_ID=replace_with_dropbox_app_key
DROPBOX_CLIENT_SECRET=replace_with_dropbox_app_secret
DROPBOX_REFRESH_TOKEN=replace_with_refresh_token

# Optional. For GHF's shared/team grants namespace, this may be 5698749680.
DROPBOX_NAMESPACE_ID=

# When DROPBOX_NAMESPACE_ID is set, use the path inside that namespace.
# Do not include /D and do not use a trailing slash.
DROPBOX_ALLOWED_ROOT=/4 - Development/1 - Grants

# Use "database" after the private Postgres/Supabase index has been loaded.
SEARCH_BACKEND=dropbox

# Supabase: use the Transaction pooler connection string for Vercel/serverless.
# Keep this secret. Do not commit the real value.
DATABASE_URL=
DATABASE_MAX_CONNECTIONS=3

MAX_RESULTS_DEFAULT=5
MAX_RESULTS_LIMIT=10
MAX_EXCERPT_CHARS=2000
REQUEST_TIMEOUT_MS=20000

LOG_LEVEL=info
